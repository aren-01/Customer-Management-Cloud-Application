<h5>Settings</h5>


 <style>
    
    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 20px;
    }
    th, td {
      border: 1px solid #ccc;
      padding: 10px;
      text-align: left;
    }
    th { background: #f4f4f4; }
    input, textarea, select {
      width: 100%;
      padding: 6px;
      box-sizing: border-box;
    }
  </style>

<% if (error) { %>
  <p class="error"><%= error %></p>
<% } %>

<% if (success) { %>
  <p class="success"><%= success %></p>
<% } %>

<form method="post" action="/settings/download-sql" class="form-card">
  <button type="submit">
    Download database
  </button>
</form>